{
  "primitive_id": "web_scrape",
  "version": "v1",
  "kind": "browser_interaction",
  "description": "Fetch web pages and extract structured data for downstream workflow steps.",
  "output_contract": {
    "bridge": {
      "prompt_mode": "json_schema",
      "response_fields": [
        {
          "name": "page_html",
          "type": "string"
        },
        {
          "name": "extracted",
          "type": "object",
          "required_fields_from": "task.expectations.required_fields"
        }
      ],
      "artifact_writes": [
        {
          "path": "page.html",
          "payload_path": "page_html",
          "format": "text"
        },
        {
          "path": "extracted.json",
          "payload_path": "extracted",
          "format": "json"
        }
      ],
      "benchmark_probe": {
        "fingerprints": {
          "scrape.mode": "${workflow.primitives.web_scrape.pipeline}"
        },
        "probes": {
          "scrape.retry_count": "${workflow.primitives.web_scrape.retry_limit}",
          "scrape.navigation_depth": "${task.expectations.knobs.navigation_depth}"
        }
      }
    }
  },
  "evaluation_contract": {
    "artifact_requirements": [
      "page.html",
      "extracted.json"
    ],
    "quality_thresholds": {
      "field_completeness": 0.8,
      "grounded_field_rate": 0.75
    }
  },
  "metric_schema": [
    {
      "name": "success_rate",
      "kind": "float",
      "higher_is_better": true,
      "required": true
    },
    {
      "name": "latency_ms",
      "kind": "int",
      "higher_is_better": false,
      "required": false
    }
  ],
  "probe_schema": {
    "fingerprints": [
      "scrape.mode"
    ],
    "probes": [
      "scrape.navigation_depth",
      "scrape.retry_count"
    ]
  },
  "default_knobs": {
    "timeout_ms": 8000,
    "retry_limit": 2
  },
  "default_scenarios": [
    {
      "id": "static_page",
      "weight": 1.0
    },
    {
      "id": "dynamic_page",
      "weight": 1.2
    }
  ],
  "proposal_templates": [
    {
      "template_id": "web_scrape/fast_path",
      "title": "Fast Path",
      "hypothesis": "Reduce wait time on stable pages to improve hot-path latency.",
      "knobs": {
        "timeout_ms": 5000,
        "wait_strategy": "domcontentloaded"
      },
      "expected_signals": {
        "fingerprints": {
          "scrape.mode": "fast"
        }
      },
      "tags": [
        "latency"
      ]
    },
    {
      "template_id": "web_scrape/hardening",
      "title": "Hardening",
      "hypothesis": "Increase resilience on unstable pages by allowing controlled retries.",
      "knobs": {
        "timeout_ms": 9000,
        "retry_limit": 3
      },
      "expected_signals": {
        "probes": {
          "scrape.retry_count": {
            "max": 3
          }
        }
      },
      "tags": [
        "stability"
      ]
    }
  ]
}
