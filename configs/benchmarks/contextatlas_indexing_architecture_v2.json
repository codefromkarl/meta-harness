{
  "experiment": "contextatlas_indexing_architecture_v2",
  "baseline": "baseline_snapshot",
  "analysis_mode": "architecture",
  "repeats": 3,
  "report": {
    "group_by": ["scenario", "variant_type"],
    "primary_axes": ["quality", "mechanism", "stability", "cost"],
    "recommended_task_set": "task_sets/contextatlas/benchmark_indexing_architecture_v2.json",
    "notes": [
      "snapshot-based",
      "indexing strategy and cost evaluation skeleton"
    ]
  },
  "scenarios": [
    {
      "id": "exact_symbol_lookup",
      "label": "Exact Symbol Lookup",
      "weight": 1.0
    },
    {
      "id": "cross_file_dependency_trace",
      "label": "Cross File Dependency Trace",
      "weight": 1.0
    },
    {
      "id": "index_freshness_sensitive",
      "label": "Index Freshness Sensitive",
      "weight": 1.2
    },
    {
      "id": "recent_change_discovery",
      "label": "Recent Change Discovery",
      "weight": 1.2
    },
    {
      "id": "stale_index_recovery",
      "label": "Stale Index Recovery",
      "weight": 1.1
    },
    {
      "id": "large_repo_retrieval",
      "label": "Large Repo Retrieval",
      "weight": 0.9
    }
  ],
  "variants": [
    {
      "name": "baseline_snapshot",
      "variant_type": "parameter",
      "hypothesis": "Current snapshot-based baseline provides the comparison anchor for indexing quality and stability.",
      "implementation_id": "indexing/baseline-snapshot",
      "tags": ["baseline", "snapshot-based", "indexing"],
      "expected_signals": {
        "fingerprints": {
          "retrieval.strategy": "fts_topk_rerank"
        }
      }
    },
    {
      "name": "chunk_dense_quality_bias",
      "variant_type": "parameter",
      "hypothesis": "Denser chunking improves freshness-sensitive retrieval quality at the cost of larger index size and longer indexing latency.",
      "implementation_id": "indexing/chunk-dense-quality-bias",
      "tags": ["indexing", "quality", "cost-sensitive"],
      "config_patch": {
        "indexing": {
          "chunk_size": 1200,
          "chunk_overlap": 160
        }
      },
      "expected_signals": {
        "fingerprints": {
          "indexing.chunk_profile": "1200/160"
        }
      }
    },
    {
      "name": "chunk_compact_cost_bias",
      "variant_type": "parameter",
      "hypothesis": "More compact chunking constrains index cost and write amplification, but may reduce freshness and grounded retrieval quality.",
      "implementation_id": "indexing/chunk-compact-cost-bias",
      "tags": ["indexing", "cost", "quality-tradeoff"],
      "config_patch": {
        "indexing": {
          "chunk_size": 800,
          "chunk_overlap": 120
        }
      },
      "expected_signals": {
        "fingerprints": {
          "indexing.chunk_profile": "800/120"
        }
      }
    },
    {
      "name": "incremental_refresh_skeleton",
      "variant_type": "method_family",
      "hypothesis": "Freshness-aware incremental indexing should preserve recent-change visibility while reducing rebuild latency and peak resource usage.",
      "implementation_id": "indexing/incremental-refresh-skeleton",
      "tags": ["indexing", "method-family", "incremental", "cost-sensitive"],
      "config_patch": {
        "indexing": {
          "chunk_size": 1200,
          "chunk_overlap": 160,
          "update_mode": "incremental"
        },
        "optimization": {
          "focus": "indexing",
          "indexing_strategy_hint": "incremental_refresh"
        }
      },
      "expected_signals": {
        "fingerprints": {
          "indexing.chunk_profile": "1200/160"
        }
      }
    },
    {
      "name": "freshness_guard_skeleton",
      "variant_type": "method_family",
      "hypothesis": "Freshness-guarded indexing should recover stale snapshots more reliably, even if its indexing cost is higher than compact chunking.",
      "implementation_id": "indexing/freshness-guard-skeleton",
      "tags": ["indexing", "method-family", "freshness", "recovery"],
      "config_patch": {
        "indexing": {
          "chunk_size": 1200,
          "chunk_overlap": 160,
          "update_mode": "incremental",
          "freshness_guard": true
        },
        "optimization": {
          "focus": "indexing",
          "indexing_strategy_hint": "freshness_guard"
        }
      },
      "expected_signals": {
        "fingerprints": {
          "indexing.chunk_profile": "1200/160"
        }
      }
    }
  ]
}
