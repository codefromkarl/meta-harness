{
  "tasks": [
    {
      "task_id": "contextatlas-benchmark",
      "workdir": "${workspace_dir}",
      "phases": [
        {
          "phase": "install_dependencies",
          "command": [
            "pnpm",
            "install",
            "--frozen-lockfile"
          ]
        },
        {
          "phase": "register_project",
          "command": [
            "node",
            "--import",
            "tsx",
            "src/index.ts",
            "hub:register-project",
            "${workspace_dir}",
            "--name",
            "ContextAtlas"
          ]
        },
        {
          "phase": "import_profile",
          "command": [
            "node",
            "--import",
            "tsx",
            "src/index.ts",
            "profile:import-omc"
          ]
        },
        {
          "phase": "build",
          "command": [
            "pnpm",
            "build"
          ]
        },
        {
          "phase": "index_workspace",
          "command": [
            "node",
            "--import",
            "tsx",
            "src/index.ts",
            "index",
            "${workspace_dir}"
          ]
        },
        {
          "phase": "test_omc_import",
          "command": [
            "node",
            "--import",
            "tsx",
            "--test",
            "tests/omc-profile-import.test.ts"
          ]
        },
        {
          "phase": "show_profile",
          "command": [
            "node",
            "--import",
            "tsx",
            "src/index.ts",
            "profile:show"
          ]
        },
        {
          "phase": "check_memory",
          "command": [
            "node",
            "--import",
            "tsx",
            "src/index.ts",
            "memory:check-consistency"
          ]
        },
        {
          "phase": "health_check",
          "command": [
            "node",
            "--import",
            "tsx",
            "/home/yuanzhi/Develop/tools/meta-harness/scripts/contextatlas_health_check.ts",
            "--project-id",
            "${contextatlas.project_id}"
          ]
        },
        {
          "phase": "benchmark_probe",
          "command": [
            "node",
            "--import",
            "tsx",
            "/home/yuanzhi/Develop/tools/meta-harness/scripts/contextatlas_benchmark_probe.ts",
            "--project-id",
            "${contextatlas.project_id}"
          ]
        }
      ]
    }
  ]
}
