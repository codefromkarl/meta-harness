{
  "tasks": [
    {
      "task_id": "contextatlas-maintenance",
      "workdir": "${contextatlas.repo_path}",
      "phases": [
        {
          "phase": "register_project",
          "command": [
            "node",
            "--import",
            "tsx",
            "src/index.ts",
            "hub:register-project",
            "${contextatlas.repo_path}",
            "--name",
            "ContextAtlas"
          ]
        },
        {
          "phase": "import_profile",
          "command": [
            "node",
            "--import",
            "tsx",
            "src/index.ts",
            "profile:import-omc"
          ]
        },
        {
          "phase": "show_profile",
          "command": [
            "node",
            "--import",
            "tsx",
            "src/index.ts",
            "profile:show"
          ]
        },
        {
          "phase": "check_memory",
          "command": [
            "node",
            "--import",
            "tsx",
            "src/index.ts",
            "memory:check-consistency"
          ]
        },
        {
          "phase": "health_check",
          "command": [
            "node",
            "--import",
            "tsx",
            "src/index.ts",
            "health:check",
            "--json",
            "--project-id",
            "${contextatlas.project_id}"
          ]
        }
      ]
    }
  ]
}
